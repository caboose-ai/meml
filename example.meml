# caboose-mcp.meml
# Example MEML config for the caboose-mcp server
# Meme Markup Language — https://github.com/caboose-mcp/meml

# Root-level keys (no section)
claude_dir = ~/.claude

[🔧 server]
host = "0.0.0.0"
port = 8080
debug = false
status = 🟢

[🔑 slack]
🔑 token     = ""          # xoxb-... Bot OAuth token
🔑 app_token = ""          # xapp-... for Socket Mode
channels     = []          # comma-separated channel IDs

[🔑 discord]
🔑 token       = ""
🔑 webhook_url = ""
channels       = []
🔑 anthropic_api_key = ""

[🖨️ bambu]
ip          = ""
🔑 access_code = ""
serial      = ""
bed_temp    = 55
nozzle_temp = 220

[💾 database]
🌍 postgres_url = "postgres://user:pass@localhost:5432/dbname"
🌍 mongo_url    = "mongodb://localhost:27017"

[🔑 secrets]
gpg_key_id = ""

[🔍 greptile]
🔑 api_key = ""
repo       = "github/caboose/caboose-mcp"

[🐙 github]
🔑 token = ""

☁️ cloudsync_s3_bucket = ""  # e.g. my-config-bucket

[⚡ n8n]
🌍 webhook_url = ""
🔑 api_key     = ""
